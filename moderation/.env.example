# .env
DB_HOST=postgres
DB_PORT=5432
DB_NAME=neomarket_moderation
DB_USER=postgres
DB_PASS=postgres

# B2B Service
B2B_SERVICE_URL=http://b2b-service:8000
B2B_TIMEOUT=30

# Auth
BYPASS_AUTH=True DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neomarket_b2b

#В Docker-окружении DB_HOST должен быть postgres (имя сервиса), а не localhost. 
#Это уже настроено в docker-compose.yml.